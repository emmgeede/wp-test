msgstr "태그 편집/카테고리 편집."

msgid "View Tag/View Category."
msgstr "태그 보기/카테고리 보기."

msgid "Update item"
msgstr "항목 업데이트"

msgid "Update Tag/Update Category."
msgstr "태그 업데이트/카테고리 업데이트."

msgid "Add New Tag/Add New Category."
msgstr "새 태그 추가/새 카테고리 추가."

msgid "New item name"
msgstr "새 항목 이름"

